function nextSlide() {
    // Text change
    let randomStory = stories[Math.floor(Math.random() * stories.length)];
    document.getElementById("desc").innerText = randomStory;
    
    // Image change (Infinite random)
    let randomID = Math.floor(Math.random() * 10000);
    document.getElementById("bg-container").style.backgroundImage = 
        "url('https://picsum.photos/1600/900?random=" + randomID + "')";
