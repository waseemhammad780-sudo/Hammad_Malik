        height: 100vh; display: flex; flex-direction: column; 
        justify-content: center; align-items: center; text-align: center;
        background-size: cover; background-position: center; transition: 0.5s;
        background-image: url('https://picsum.photos/1600/900?random=1');
    }
    #content-box { 
        background: rgba(0, 0, 0, 0.8); padding: 30px; 
        border: 1px solid #ff4757; border-radius: 15px; color: white;
    }
    h1 { margin: 0; color: #ff4757; }
    button { 
        margin-top: 20px; background: #ff4757; border: none; 
        padding: 12px 25px; border-radius: 25px; color: white; cursor: pointer; font-weight: bold;
    }
</style>
</head>
